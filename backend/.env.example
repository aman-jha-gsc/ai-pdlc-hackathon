# DESCRIPTION: Example environment variables required for the backend application.

# --- Database ---
# Connection string for your PostgreSQL database
DATABASE_URL="postgresql://user:password@localhost:5432/claritydb?schema=public"

# --- Authentication ---
# A long, random, secret string for signing JWTs
JWT_SECRET="your-super-secret-jwt-string-that-is-very-long"

# --- Security ---
# A 32-character (256-bit) random string for encrypting sensitive data like Plaid tokens
ENCRYPTION_KEY="your-super-secret-32-char-key!!"

# --- Plaid API ---
# Get these from your Plaid dashboard (https://dashboard.plaid.com/)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# Set to 'sandbox', 'development', or 'production'
PLAID_ENV="sandbox"

# --- Application ---
PORT=8000
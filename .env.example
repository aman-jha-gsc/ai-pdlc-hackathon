# Copy this file to .env.local and fill in the values.

# Prisma
# Use a PostgreSQL connection string. For local dev with docker-compose, this is correct.
# For production (e.g., Vercel), use the connection string from your database provider (e.g., Supabase, Neon).
DATABASE_URL="postgresql://user:password@localhost:5432/budgetapp?schema=public"

# NextAuth.js
# A random string used to hash tokens, sign cookies and generate cryptographic keys.
# You can generate one with `openssl rand -base64 32`
NEXTAUTH_SECRET="your-super-secret-nextauth-secret"
# The canonical URL of your production site.
# For local development, it's http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"